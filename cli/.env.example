# Required: bearer token for the webterminal API. Create one from the
# webterminal SPA's "API Tokens" dialog (the full secret is shown only
# once), or run `mics_cli login` to mint one with username/password.
MICS_TOKEN=agt_replace_me

# Required: base URL of your webterminal site. Accepts either form,
# with or without a trailing /api:
#   MICS_URL=https://term.example.com
#   MICS_URL=https://term.example.com/api
MICS_URL=https://term.example.com
