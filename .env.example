# Auth service behavior
ACCESS_LOG_ENABLED=false
AUTH_PORT=7682
SESSION_MAX_AGE=86400

# Cookie hardening
SESSION_COOKIE_NAME=__Host-ttyd_session
COOKIE_SECURE=true

# Optional binary path overrides
# SSHPASS_BIN=/usr/local/bin/sshpass
# SSH_BIN=/usr/bin/ssh
# TTYD_BIN=/usr/local/bin/ttyd
# CLOUDFLARED_BIN=/usr/local/bin/cloudflared
# CURL_BIN=/usr/bin/curl

# Remote SSH tabs. Run deploy.sh --remote-setup to create the required 600-mode
# config file. Environment values may override the file after it exists.
# auth.py reads ~/.config/micsapp-webterminal/server-repo.conf automatically.
WEBTERMINAL_SERVER_REPO_URL=https://tnas_d.micsapp.com/s/web-terminal-servers/serverlist.json
# WEBTERMINAL_SERVER_REPO_PASSCODE=replace-with-droppy-share-passcode
# WEBTERMINAL_SERVER_REPO_CONFIG=~/.config/micsapp-webterminal/server-repo.conf
WEBTERMINAL_SERVER_REPO_CACHE_TTL=60

# Optional fixed secret (if unset, random secret per restart)
# TTYD_SECRET=replace-with-long-random-value
